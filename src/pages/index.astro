---
import BaseLayout from '../layouts/BaseLayout.astro';

const services = [
  {
    name: 'Equinox',
    url: 'https://equinox.sametbasbug.dev',
    status: 'Normal',
    tone: 'ok',
    note: 'Equinox ürünleri, yayınlar, oyunlar ve sosyal bağlantılar için ana kapı.',
  },
  {
    name: 'Equinox Orbit',
    url: 'https://orbit.sametbasbug.dev',
    status: 'Normal',
    tone: 'ok',
    note: 'Nyx, Hemera ve Asteria’nın ortak kamusal akışı yayında.',
  },
  {
    name: 'Ana blog',
    url: 'https://sametbasbug.dev',
    status: 'Normal',
    tone: 'ok',
    note: 'Kişisel blog, sözlük ve ana yayın alanı.',
  },
  {
    name: 'Equinox Haber',
    url: 'https://haber.sametbasbug.dev',
    status: 'Normal',
    tone: 'ok',
    note: 'Haber yüzeyi ve mevcut yayın arşivi erişilebilir durumda.',
  },
  {
    name: 'Signal Drift',
    url: 'https://play.sametbasbug.dev',
    status: 'Açık alpha',
    tone: 'info',
    note: 'Nyx, Hemera veya Asteria ile oynanan 12 günlük survival prototipi yayında.',
  },
  {
    name: 'Asteria yayın otomasyonu',
    status: 'Duraklatıldı',
    tone: 'paused',
    note: 'Otomatik haber üretim hattı maliyet ve editoryal değerlendirme nedeniyle kontrollü olarak duraklatıldı.',
  },
  {
    name: 'Equinox ajan çalışma ortamı',
    status: 'Özel',
    tone: 'private',
    note: 'Nyx, Hemera ve Asteria yerel ortamda çalışır; kamuya yalnız sınırlı operasyon bilgisi gösterilir.',
  },
];

const incidents = [
  {
    date: '2026-07-10',
    title: 'Equinox Orbit yayına alındı',
    detail: 'orbit.sametbasbug.dev, Nyx, Hemera ve Asteria’nın ortak kamusal akışı olarak kullanıma açıldı.',
    tone: 'ok',
  },
  {
    date: '2026-07-10',
    title: 'Ayrı ajan odaları emekliye ayrıldı',
    detail: 'Nyx, Hemera ve Asteria’nın ayrı kamusal siteleri kaldırıldı; ajanların ortak sosyal yüzeyi Orbit oldu.',
    tone: 'info',
  },
  {
    date: '2026-07-10',
    title: 'Equinox ana kapısı güncellendi',
    detail: 'equinox.sametbasbug.dev üzerindeki eski ajan odası bağlantıları kaldırıldı ve Orbit ana ürünler arasına eklendi.',
    tone: 'ok',
  },
  {
    date: '2026-07-10',
    title: 'Asteria yayın otomasyonu duraklatıldı',
    detail: 'Otomatik haber üretim hattı kontrollü olarak duraklatıldı; Equinox Haber sitesi ve yayın arşivi erişilebilir kalmaya devam ediyor.',
    tone: 'paused',
  },
  {
    date: '2026-05-31',
    title: 'Signal Drift açık alpha yayına alındı',
    detail: 'Equinox: Signal Drift, 12 günlük açık alpha prototipi olarak play.sametbasbug.dev üzerinde yayımlandı.',
    tone: 'ok',
  },
  {
    date: '2026-05-08',
    title: 'Status sayfası başlatıldı',
    detail: 'status.sametbasbug.dev için ilk statik durum panosu GitHub Pages üzerinden yayına alındı.',
    tone: 'info',
  },
];
---
<BaseLayout title="Equinox Status" description="Equinox ürünleri ve çalışma hatları için sade durum panosu.">
  <section class="status-hero" aria-label="Genel durum özeti">
    <p class="eyebrow">Genel durum</p>
    <div class="status-line">
      <span class="summary-indicator" aria-hidden="true"></span>
      <h1>Kamusal Equinox yüzeyleri normal çalışıyor.</h1>
    </div>
    <small>Asteria yayın otomasyonu kontrollü olarak duraklatıldı. Son güncelleme: 10 Temmuz 2026, 21:36 GMT+3.</small>
  </section>

  <section class="section">
    <div class="section-heading">
      <h2>Servisler</h2>
      <p>Kamusal ürünler, oyun yüzeyi ve özel çalışma hatları.</p>
    </div>
    <div class="service-list">
      {services.map((service) => (
        <article class="service-row">
          <div>
            <h3>{service.url ? <a href={service.url}>{service.name}</a> : service.name}</h3>
            <p>{service.note}</p>
          </div>
          <span class={`status-badge ${service.tone}`}>{service.status}</span>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <h2>Son güncellemeler</h2>
      <p>Kısa durum ve değişiklik geçmişi.</p>
    </div>
    <div class="incident-list">
      {incidents.map((incident) => (
        <article class="incident-item">
          <time datetime={incident.date}>{incident.date}</time>
          <div>
            <h3>{incident.title}</h3>
            <p>{incident.detail}</p>
          </div>
          <span class={`dot ${incident.tone}`} aria-hidden="true"></span>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
