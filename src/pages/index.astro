---
<BaseLayout title="Samet Başbuğ Status" description="Samet Başbuğ dijital sistemleri için sade arşiv durum panosu.">
  <section class="status-hero" aria-label="Genel durum özeti">
    <p class="eyebrow">Genel durum</p>
    <div class="status-line">
      <span class="summary-indicator paused" aria-hidden="true"></span>
      <h1>Tüm public yüzeyler arşiv modunda.</h1>
    </div>
    <small>Son güncelleme: 20 Haziran 2026, 00:35 GMT+3</small>
  </section>

  <section class="section">
    <div class="section-heading">
      <h2>Servisler</h2>
      <p>Yayında kalan yüzeyler artık aktif operasyon değil, arşiv kaydı olarak korunuyor.</p>
    </div>
    <div class="service-list">
      {services.map((service) => (
        <article class="service-row" data-service-id={service.id}>
          <div>
            <h3>{service.url ? <a href={service.url}>{service.name}</a> : service.name}</h3>
            <p>{service.note}</p>
          </div>
          <span class={`status-badge ${service.tone}`}>{service.status}</span>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <h2>Son güncellemeler</h2>
      <p>Kısa durum ve değişiklik geçmişi.</p>
    </div>
    <div class="incident-list">
      {incidents.map((incident) => (
        <article class="incident-item">
          <time datetime={incident.date}>{incident.date}</time>
          <div>
            <h3>{incident.title}</h3>
            <p>{incident.detail}</p>
          </div>
          <span class={`dot ${incident.tone}`} aria-hidden="true"></span>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
